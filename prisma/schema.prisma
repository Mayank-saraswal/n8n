// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id
  name             String
  email            String
  emailVerified    Boolean      @default(false)
  image            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt
  sessions         Session[]
  accounts         Account[]
  workflows        workflow[]
  credentials      Credential[]
  executionCount   Int          @default(0)
  executionResetAt DateTime     @default(now())

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model workflow {
  id   String @id @default(cuid())
  name String

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  nodes             Node[]
  connections       Connection[]
  executions        Execution[]
  webhookTrigger    WebhookTrigger?
  scheduleTrigger   ScheduleTrigger?
  ifElseNodes       IfElseNode[]
  gmailNodes        GmailNode[]
  setVariableNodes  SetVariableNode[]
  googleSheetsNodes GoogleSheetsNode[]
  googleDriveNodes  GoogleDriveNode[]
  codeNodes         CodeNode[]
  whatsAppNodes     WhatsAppNode[]
  loopNodes         LoopNode[]
  notionNodes       NotionNode[]
  razorpayNodes     RazorpayNode[]
  slackNodes        SlackNode[]
  gmailWatchers     GmailWatcher[]
  switchNodes       SwitchNode[]
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NodeType {
  INITIAL
  MANUAL_TRIGGER
  HTTP_REQUEST
  GOOGLE_FORM_TRIGGER
  STRIPE_TRIGGER
  WEBHOOK_TRIGGER
  SCHEDULE_TRIGGER
  ANTHROPIC
  GEMINI
  OPENAI
  GROQ
  XAI
  DISCORD
  SLACK
  DEEPSEEK
  PERPLEXITY
  TELEGRAM
  X
  WORKDAY
  IF_ELSE
  GMAIL
  SET_VARIABLE
  GOOGLE_SHEETS
  GOOGLE_DRIVE
  CODE
  WHATSAPP
  LOOP
  NOTION
  RAZORPAY
  SWITCH
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
}

model WebhookTrigger {
  id          String     @id @default(cuid())
  workflowId  String     @unique
  webhookId   String     @unique @default(uuid())
  secretToken String
  isActive    Boolean    @default(true)
  httpMethod  HttpMethod @default(POST)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([workflowId])
}

model ScheduleTrigger {
  id                String    @id @default(cuid())
  workflowId        String    @unique
  cronExpression    String
  timezone          String    @default("UTC")
  isActive          Boolean   @default(true)
  inngestFunctionId String    @unique
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Credential {
  id     String         @id @default(cuid())
  name   String
  value  String
  userId String
  type   CredentialType
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  Node   Node[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("Credenial")
}

enum CredentialType {
  OPENAI
  ANTHROPIC
  GEMINI
  DEEPSEEK
  PERPLEXITY
  XAI
  GROQ
  GMAIL
  GMAIL_OAUTH
  GOOGLE_SHEETS
  GOOGLE_DRIVE
  WHATSAPP
  NOTION
  RAZORPAY
  SLACK
}

model Node {
  id                String       @id @default(cuid())
  name              String
  type              NodeType
  workflowId        String
  position          Json
  data              Json         @default("{}")
  outputConnections Connection[] @relation("FromNode")
  inputConnections  Connection[] @relation("ToNode")
  workflow          workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  credentialId      String?
  credential        Credential?  @relation(fields: [credentialId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
}

model Connection {
  id         String   @id @default(cuid())
  workflowId String
  workflow   workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromNodeId String
  fromNode   Node     @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String
  toNode     Node     @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  fromOutput String   @default("main")
  toInput    String   @default("main")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Execution {
  id             String          @id @default(cuid())
  workflowId     String
  workflow       workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  inngestEventId String          @unique
  output         Json?
  error          String?         @db.Text
  errorStack     String?         @db.Text
  status         ExecutionStatus @default(RUNNING)
}

enum IfElseOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  NOT_CONTAINS
  STARTS_WITH
  ENDS_WITH
  GREATER_THAN
  LESS_THAN
  GREATER_THAN_OR_EQUAL
  LESS_THAN_OR_EQUAL
  IS_EMPTY
  IS_NOT_EMPTY
  IS_TRUE
  IS_FALSE
  REGEX_MATCH
}

model IfElseNode {
  id         String @id @default(cuid())
  workflowId String
  nodeId     String @unique

  // Condition configuration (legacy single-condition fields, kept for backward compatibility)
  field    String         @default("")
  operator IfElseOperator @default(EQUALS)
  value    String         @default("")

  // Compound conditions JSON (AND/OR groups)
  conditionsJson String @default("") @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model SwitchNode {
  id           String   @id @default(cuid())
  nodeId       String   @unique
  workflowId   String
  variableName String   @default("switch")
  casesJson    String   @default("[]") @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workflow     workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([nodeId])
}

enum GmailOperation {
  SEND
  REPLY
  FORWARD
  GET_MESSAGE
  LIST_MESSAGES
  SEARCH_MESSAGES
  ADD_LABEL
  REMOVE_LABEL
  MARK_READ
  MARK_UNREAD
  MOVE_TO_TRASH
  CREATE_DRAFT
  GET_ATTACHMENT
  GET_THREAD
  LIST_LABELS
  CREATE_LABEL
  LIST_DRAFTS
  SEND_DRAFT
}

model GmailNode {
  id           String         @id @default(cuid())
  workflowId   String
  nodeId       String         @unique
  credentialId String

  operation    GmailOperation @default(SEND)
  variableName String         @default("gmail")

  // Email fields — support template variables like {{body.name}}
  to      String  @default("")
  subject String  @default("")
  body    String  @default("") @db.Text
  isHtml  Boolean @default(false)

  // New fields for extended operations
  cc              String   @default("")
  bcc             String   @default("")
  replyTo         String   @default("")
  messageId       String   @default("")
  threadId        String   @default("")
  searchQuery     String   @default("")
  maxResults      Int      @default(10)
  labelIds        String   @default("")
  includeBody     Boolean  @default(true)
  includeHeaders  Boolean  @default(false)
  pageToken       String   @default("")
  attachmentData  String   @default("") @db.Text
  attachmentName  String   @default("")
  attachmentMime  String   @default("application/octet-stream")

  // New fields for extended operations
  attachmentId           String @default("")
  attachmentOutputFormat String @default("base64")
  removeLabelIds         String @default("")
  labelName              String @default("")
  draftId                String @default("")
  messageIds             String @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model GmailWatcher {
  id            String   @id @default(cuid())
  workflowId    String
  nodeId        String   @unique
  credentialId  String
  email         String
  active        Boolean  @default(true)
  lastHistoryId String   @default("")
  expiration    String   @default("")
  filterQuery   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workflow      workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([email, active])
}

model SetVariableNode {
  id         String   @id @default(cuid())
  nodeId     String   @unique
  workflowId String
  pairs      Json // stores array of {key: string, value: string}
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum GoogleSheetsOp {
  APPEND_ROW
  READ_ROWS
  UPDATE_ROW
  UPDATE_ROWS_BY_QUERY
  DELETE_ROW
  GET_ROW_BY_NUMBER
  SEARCH_ROWS
  CLEAR_RANGE
  CREATE_SHEET
  GET_SHEET_INFO
}

model GoogleSheetsNode {
  id               String         @id @default(cuid())
  nodeId           String         @unique
  workflowId       String
  operation        GoogleSheetsOp @default(APPEND_ROW)
  spreadsheetId    String         @default("")
  sheetName        String         @default("Sheet1")
  range            String         @default("A:Z")
  rowData          Json           @default("[]")
  credentialId     String         @default("")
  variableName     String         @default("googleSheets")
  headerRow        Boolean        @default(true)
  rowNumber        String         @default("")
  rowValues        String         @default("") @db.Text
  searchColumn     String         @default("")
  searchValue      String         @default("")
  clearRange       String         @default("")
  newSheetName     String         @default("")
  valueInputOption String         @default("USER_ENTERED")
  matchColumn      String         @default("")
  matchValue       String         @default("")
  updateValues     String         @default("") @db.Text
  maxResults       Int            @default(100)
  includeEmptyRows Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum GoogleDriveOperation {
  UPLOAD_FILE
  DOWNLOAD_FILE
  LIST_FILES
  CREATE_FOLDER
}

model GoogleDriveNode {
  id           String               @id @default(cuid())
  nodeId       String               @unique
  workflowId   String
  credentialId String?
  operation    GoogleDriveOperation @default(UPLOAD_FILE)
  folderId     String?
  fileId       String?
  fileName     String?
  mimeType     String?
  query        String?
  maxResults   Int                  @default(10)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  workflow     workflow             @relation(fields: [workflowId], references: [id])
}

model CodeNode {
  id         String   @id @default(cuid())
  nodeId     String   @unique
  workflowId String
  code       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum WhatsAppOperation {
  SEND_TEXT
  SEND_TEMPLATE
  SEND_IMAGE
  SEND_DOCUMENT
  SEND_REACTION
}

model WhatsAppNode {
  id             String            @id @default(cuid())
  nodeId         String            @unique
  workflowId     String
  credentialId   String?
  operation      WhatsAppOperation @default(SEND_TEXT)
  to             String            @default("")
  body           String            @default("") @db.Text
  templateName   String            @default("")
  templateLang   String            @default("en_US")
  templateParams String            @default("[]")
  mediaUrl       String            @default("")
  mediaCaption   String            @default("")
  reactionEmoji  String            @default("")
  reactionMsgId  String            @default("")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  workflow       workflow          @relation(fields: [workflowId], references: [id])
}

model LoopNode {
  id            String   @id @default(cuid())
  nodeId        String   @unique
  workflowId    String
  inputPath     String   @default("googleSheets.rows")
  itemVariable  String   @default("item")
  maxIterations Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum NotionOperation {
  QUERY_DATABASE
  CREATE_DATABASE_PAGE
  UPDATE_DATABASE_PAGE
  GET_PAGE
  ARCHIVE_PAGE
  APPEND_BLOCK
  GET_BLOCK_CHILDREN
  SEARCH
  GET_DATABASE
  GET_USER
  GET_USERS
}

model NotionNode {
  id             String          @id @default(cuid())
  nodeId         String          @unique
  workflowId     String
  credentialId   String?
  operation      NotionOperation @default(QUERY_DATABASE)
  databaseId     String          @default("")
  pageId         String          @default("")
  blockContent   String          @default("") @db.Text
  searchQuery    String          @default("")
  filterJson     String          @default("{}") @db.Text
  sortsJson      String          @default("[]") @db.Text
  propertiesJson String          @default("{}") @db.Text
  notionUserId   String          @default("")
  pageSize       Int             @default(100)
  startCursor    String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum RazorpayOperation {
  ORDER_CREATE
  ORDER_FETCH
  ORDER_FETCH_PAYMENTS
  ORDER_LIST
  PAYMENT_FETCH
  PAYMENT_CAPTURE
  PAYMENT_LIST
  PAYMENT_UPDATE
  REFUND_CREATE
  REFUND_FETCH
  REFUND_LIST
  CUSTOMER_CREATE
  CUSTOMER_FETCH
  CUSTOMER_UPDATE
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_FETCH
  SUBSCRIPTION_CANCEL
  INVOICE_CREATE
  INVOICE_FETCH
  INVOICE_SEND
  INVOICE_CANCEL
  PAYMENT_LINK_CREATE
  PAYMENT_LINK_FETCH
  PAYMENT_LINK_UPDATE
  PAYMENT_LINK_CANCEL
  PAYOUT_CREATE
  PAYOUT_FETCH
  VERIFY_PAYMENT_SIGNATURE
}

model RazorpayNode {
  id                String             @id @default(cuid())
  nodeId            String             @unique
  workflowId        String
  credentialId      String?
  operation         RazorpayOperation  @default(ORDER_CREATE)
  variableName      String             @default("razorpay")
  amount            String             @default("")
  currency          String             @default("INR")
  description       String             @default("")
  receipt           String             @default("")
  notes             String             @default("")
  partialPayment    Boolean            @default(false)
  orderId           String             @default("")
  paymentId         String             @default("")
  captureAmount     String             @default("")
  refundAmount      String             @default("")
  refundSpeed       String             @default("normal")
  refundId          String             @default("")
  customerId        String             @default("")
  customerName      String             @default("")
  customerEmail     String             @default("")
  customerContact   String             @default("")
  failExisting      Boolean            @default(false)
  planId            String             @default("")
  totalCount        String             @default("")
  quantity          String             @default("1")
  startAt           String             @default("")
  subscriptionId    String             @default("")
  cancelAtCycleEnd  Boolean            @default(false)
  invoiceType       String             @default("invoice")
  lineItems         String             @default("")
  expireBy          String             @default("")
  smsNotify         Boolean            @default(true)
  emailNotify       Boolean            @default(true)
  invoiceId         String             @default("")
  paymentLinkId     String             @default("")
  referenceId       String             @default("")
  reminderEnable    Boolean            @default(true)
  callbackUrl       String             @default("")
  callbackMethod    String             @default("")
  accountNumber     String             @default("")
  fundAccountId     String             @default("")
  payoutMode        String             @default("")
  payoutPurpose     String             @default("payout")
  narration         String             @default("")
  queueIfLowBalance Boolean           @default(false)
  payoutId          String             @default("")
  signature         String             @default("")
  throwOnInvalid    Boolean            @default(true)
  count             String             @default("")
  skip              String             @default("")
  fromDate          String             @default("")
  toDate            String             @default("")
  authorized        String             @default("")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum SlackOperation {
  MESSAGE_SEND_WEBHOOK
  MESSAGE_SEND
  MESSAGE_UPDATE
  MESSAGE_DELETE
  MESSAGE_GET_PERMALINK
  MESSAGE_SCHEDULE
  // legacy — kept for backward compat
  MESSAGE_SEARCH
  CHANNEL_GET
  CHANNEL_LIST
  CHANNEL_CREATE
  CHANNEL_ARCHIVE
  CHANNEL_UNARCHIVE
  CHANNEL_INVITE
  CHANNEL_KICK
  CHANNEL_SET_TOPIC
  CHANNEL_SET_PURPOSE
  // legacy — kept for backward compat
  CHANNEL_HISTORY
  CHANNEL_INFO
  CHANNEL_RENAME
  USER_GET
  USER_GET_BY_EMAIL
  USER_LIST
  USER_SET_STATUS
  // legacy — kept for backward compat
  USER_INFO
  USER_GET_PRESENCE
  REACTION_ADD
  REACTION_REMOVE
  REACTION_GET
  FILE_UPLOAD
  FILE_GET
  FILE_DELETE
  // legacy — kept for backward compat
  FILE_LIST
  FILE_INFO
  CONVERSATION_OPEN
}

model SlackNode {
  id               String         @id @default(cuid())
  nodeId           String         @unique
  workflowId       String
  credentialId     String?
  operation        SlackOperation @default(MESSAGE_SEND_WEBHOOK)
  variableName     String         @default("slack")
  channel          String         @default("")
  message          String         @default("") @db.Text
  threadTs         String         @default("")
  messageTs        String         @default("")
  searchQuery      String         @default("")
  channelName      String         @default("")
  channelTopic     String         @default("")
  channelPurpose   String         @default("")
  userId           String         @default("")
  emoji            String         @default("")
  fileComment      String         @default("")
  webhookUrl       String         @default("")
  blockKit         String         @default("") @db.Text
  botName          String         @default("")
  iconEmoji        String         @default("")
  unfurlLinks      Boolean        @default(true)
  channelTypes     String         @default("public_channel,private_channel")
  limit            Int            @default(100)
  excludeArchived  Boolean        @default(true)
  isPrivate        Boolean        @default(false)
  filename         String         @default("")
  fileType         String         @default("")
  title            String         @default("")
  initialComment   String         @default("")
  email            String         @default("")
  statusText       String         @default("")
  statusEmoji      String         @default("")
  statusExpiration String         @default("")
  sendAt           String         @default("")
  content          String         @default("") @db.Text
  fileId           String         @default("")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}
